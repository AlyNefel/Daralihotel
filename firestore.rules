rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Fields: name, description, pricePerNight, type, capacity, amenities, images, isAvailable
    //
    // Collection: bookings
    // Fields: roomId, userId, startDate, endDate, status, totalPrice, guestName, guestEmail, createdAt
    //
    // Collection: users
    // Fields: email, displayName, role, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ali.essoudani@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidRoom(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.pricePerNight is number && data.pricePerNight > 0 &&
             data.capacity is number && data.capacity > 0 &&
             data.type in ['Single', 'Double', 'Suite', 'Deluxe'];
    }

    function isValidBooking(data) {
      return data.roomId is string &&
             data.userId == request.auth.uid &&
             data.startDate is string &&
             data.endDate is string &&
             data.totalPrice is number && data.totalPrice > 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow write: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
